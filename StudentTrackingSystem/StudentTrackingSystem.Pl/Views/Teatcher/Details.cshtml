@model StudentTrackingSystem.DAL.Models.Teatcher

@{
    ViewData["Title"] = "Teacher Details";
}

<h2 class="section-title text-center mb-4">Teacher Details</h2>

<div class="table-responsive mt-4">
    <table class="table table-bordered table-hover text-center">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Subject</th>
                <th>Gender</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.FullName</td>
                <td>@Model.Email</td>
                <td>@Model.PhoneNumber</td>
                <td>@Model.Subject</td>
                <td>@Model.Gender</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning mb-1">Edit</a>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-1">Back</a>
                </td>
            </tr>
        </tbody>
    </table>
</div>
